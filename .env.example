# Public Supabase project URL
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Public anon key (safe for browser use when RLS is enabled)
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Never expose service_role key in frontend code or client env files.
# Keep SUPABASE_SERVICE_ROLE_KEY only on trusted server environments.
